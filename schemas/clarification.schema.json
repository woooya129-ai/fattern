{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fattern.local/schemas/clarification.schema.json",
  "title": "ClarificationRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "blocking", "questions"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "blocking": {
      "type": "boolean"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "question", "allowed_answers"],
        "properties": {
          "field": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "question": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "allowed_answers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "minItems": 1
          }
        }
      }
    }
  }
}

