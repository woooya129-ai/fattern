{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fattern.local/schemas/mcp-tools.schema.json",
  "title": "McpToolContracts",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tools"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool_contract"
      }
    }
  },
  "$defs": {
    "opaque_id": {
      "type": "string",
      "minLength": 5,
      "maxLength": 80,
      "pattern": "^(job|file|dxf_parse|piece_set|metrics|layout|artifact)_[a-z0-9_-]{1,72}$"
    },
    "tool_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "inputSchema"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "get_estimation_questionnaire",
            "create_job",
            "register_input_file",
            "parse_dxf",
            "extract_pattern_pieces",
            "calculate_piece_metrics",
            "estimate_marker_layout",
            "render_marker_svg",
            "get_job_status",
            "export_artifacts",
            "calculate_marker_yield"
          ]
        },
        "inputSchema": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "get_estimation_questionnaire_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        }
      }
    },
    "create_job_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "job_name"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "user_note": {
          "type": "string",
          "maxLength": 500,
          "default": ""
        }
      }
    },
    "register_input_file_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "job_id", "file_name", "content_base64"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "file_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "content_base64": {
          "type": "string",
          "minLength": 1,
          "maxLength": 14000000,
          "pattern": "^[A-Za-z0-9+/]*={0,2}$"
        }
      }
    },
    "id_only_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "job_id"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "parse_dxf_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "job_id", "file_id", "unit_hint"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "file_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "unit_hint": {
          "type": ["string", "null"],
          "enum": ["auto", "mm", "cm", "m", "inch", "ft", "yd", null],
          "default": "auto"
        },
        "layer_profile": {
          "type": ["string", "null"],
          "maxLength": 80,
          "default": null
        }
      }
    },
    "extract_pattern_pieces_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "job_id", "dxf_parse_id", "extraction_mode"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "dxf_parse_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "extraction_mode": {
          "type": "string",
          "enum": ["closed_polylines_only", "connect_lines", "mixed_entities"],
          "default": "closed_polylines_only"
        },
        "outline_layer_names": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 120
          },
          "default": []
        },
        "grainline_layer_names": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 120
          },
          "default": []
        }
      }
    },
    "calculate_piece_metrics_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "job_id", "piece_set_id", "unit"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "piece_set_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "unit": {
          "type": "string",
          "enum": ["mm", "cm", "m", "inch", "ft", "yd"],
          "default": "cm"
        },
        "dxf_unit_hint": {
          "type": "string",
          "enum": ["auto", "mm", "cm", "m", "inch", "ft", "yd"],
          "default": "auto"
        },
        "fabric_width": {
          "type": ["number", "null"],
          "minimum": 1,
          "default": null
        },
        "fabric_width_unit": {
          "type": ["string", "null"],
          "enum": ["mm", "cm", "m", "inch", "ft", "yd", null],
          "default": null
        },
        "curve_flattening_tolerance": {
          "type": "number",
          "minimum": 0.01,
          "default": 0.2
        },
        "seam_allowance_width": {
          "type": "number",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "estimate_marker_layout_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "job_id",
        "metrics_id",
        "fabric_width",
        "fabric_width_unit",
        "rotation_allowed_degrees",
        "clearance"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "metrics_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "fabric_width": {
          "type": "number",
          "minimum": 1
        },
        "cuttable_width": {
          "type": ["number", "null"],
          "minimum": 1,
          "default": null
        },
        "fabric_width_unit": {
          "type": "string",
          "enum": ["mm", "cm", "m", "inch", "ft", "yd"],
          "default": "cm"
        },
        "rotation_allowed_degrees": {
          "type": "array",
          "items": {
            "type": "integer",
            "enum": [0, 90, 180, 270]
          },
          "minItems": 1,
          "uniqueItems": true,
          "default": [0]
        },
        "clearance": {
          "type": "number",
          "minimum": 0,
          "default": 0.2
        },
        "spacing": {
          "type": ["number", "null"],
          "minimum": 0,
          "default": null
        },
        "nap_direction": {
          "type": ["string", "null"],
          "enum": ["one_way", "two_way", "none", "no_nap", "not_one_way", "unknown", null],
          "default": null
        },
        "one_way_fabric": {
          "type": ["boolean", "null"],
          "default": null
        },
        "grainline_status": {
          "type": "string",
          "enum": ["present", "missing", "unknown"],
          "default": "unknown"
        },
        "grainline_required": {
          "type": ["boolean", "null"],
          "default": null
        },
        "fabric_type": {
          "type": ["string", "null"],
          "enum": ["woven", "knit", "unknown", null],
          "default": null
        }
      }
    },
    "render_marker_svg_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "job_id", "layout_id"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "layout_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "get_job_status_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "job_id"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_id": {
          "$ref": "#/$defs/opaque_id"
        }
      }
    },
    "export_artifacts_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "job_id", "artifact_ids"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "job_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "artifact_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/opaque_id"
          },
          "minItems": 1,
          "maxItems": 20
        },
        "archive_format": {
          "type": "string",
          "enum": ["zip"],
          "default": "zip"
        }
      }
    },
    "calculate_marker_yield_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "pattern_file_id",
        "fabric_width",
        "unit",
        "size_ratio",
        "spacing",
        "allowed_rotation",
        "grainline_required",
        "nap_direction",
        "shrinkage_percent",
        "fabric_type",
        "seam_allowance"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1.0"
        },
        "pattern_file_id": {
          "$ref": "#/$defs/opaque_id"
        },
        "fabric_width": {
          "type": "number",
          "minimum": 1
        },
        "cuttable_width": {
          "type": ["number", "null"],
          "minimum": 1,
          "default": null
        },
        "unit": {
          "type": "string",
          "enum": ["mm", "cm", "m", "inch", "ft", "yd"]
        },
        "size_ratio": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._-]{0,39}$"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          },
          "default": {}
        },
        "piece_quantity": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40,
            "pattern": "^(\\*|[A-Za-z0-9][A-Za-z0-9 ._-]{0,39})$"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          },
          "default": {}
        },
        "spacing": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "allowed_rotation": {
          "type": "array",
          "items": {
            "type": "integer",
            "enum": [0, 90, 180, 270]
          },
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "default": [0]
        },
        "grainline_required": {
          "type": "boolean",
          "default": true
        },
        "nap_direction": {
          "type": "string",
          "enum": ["one_way", "two_way", "none", "no_nap", "not_one_way", "unknown"],
          "default": "unknown"
        },
        "shrinkage_percent": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "shrinkage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["length_percent", "width_percent"],
          "properties": {
            "length_percent": {
              "type": "number",
              "minimum": 0,
              "default": 0
            },
            "width_percent": {
              "type": "number",
              "minimum": 0,
              "default": 0
            }
          }
        },
        "fabric_type": {
          "type": "string",
          "enum": ["woven", "knit", "unknown"],
          "default": "unknown"
        },
        "stretch_direction": {
          "type": ["string", "null"],
          "enum": ["lengthwise", "crosswise", "bias", "unknown", null],
          "default": null
        },
        "seam_allowance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["included", "excluded"]
            },
            "fallback_width": {
              "type": ["number", "null"],
              "minimum": 0,
              "default": null
            }
          }
        },
        "allowance_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["fast_quote", "sample_estimate", "bulk_precheck"],
              "default": "fast_quote"
            },
            "rounding_unit": {
              "type": ["number", "null"],
              "exclusiveMinimum": 0,
              "default": null
            },
            "base_buffer_percent": {
              "type": ["number", "null"],
              "minimum": 0,
              "default": null
            },
            "cutting_loss_percent": {
              "type": ["number", "null"],
              "minimum": 0,
              "default": null
            },
            "end_loss_length": {
              "type": ["number", "null"],
              "minimum": 0,
              "default": null
            },
            "fabric_defect_buffer_percent": {
              "type": ["number", "null"],
              "minimum": 0,
              "default": null
            },
            "unknown_risk_buffer_percent": {
              "type": ["number", "null"],
              "minimum": 0,
              "default": null
            },
            "apply_warning_penalty": {
              "type": "boolean",
              "default": true
            }
          },
          "default": {}
        }
      }
    }
  }
}
